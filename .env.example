# Base URL of the NestJS API (no trailing slash, no /api/v1 — the client appends it).
#
# Per-environment config (committed, so it "just works"):
#   .env.production   -> https://api.foregrowsolutions.com   (used by `next build` / `next start`)
#   .env.development  -> http://localhost:3001               (used by `next dev`)
#
# .env.local overrides BOTH and is gitignored — only create it for a personal override,
# and DO NOT keep it on the production server (it would shadow .env.production).
#
# NOTE: NEXT_PUBLIC_* vars are inlined at build time — rebuild after changing this.
NEXT_PUBLIC_API_URL=https://api.foregrowsolutions.com
